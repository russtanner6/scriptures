{
  "bookName": "Numbers",
  "bookId": 4,
  "sentiment": [
    {"book":"Numbers","chapter":1,"exaltation":2,"peace":6,"admonition":1,"contrition":0,"dominant":"peace","rationale":"A detailed census of the twelve tribes, reflecting divine order and preparation for the journey to the promised land."},
    {"book":"Numbers","chapter":2,"exaltation":2,"peace":7,"admonition":0,"contrition":0,"dominant":"peace","rationale":"The organized arrangement of the camp around the tabernacle reflects covenantal order and divine protection."},
    {"book":"Numbers","chapter":3,"exaltation":3,"peace":7,"admonition":0,"contrition":0,"dominant":"peace","rationale":"The Levites are set apart for sacred service in lieu of every firstborn in Israel, a peaceful consecration."},
    {"book":"Numbers","chapter":4,"exaltation":2,"peace":7,"admonition":1,"contrition":0,"dominant":"peace","rationale":"Detailed instructions for the Levitical clans in transporting the tabernacle and its sacred furnishings."},
    {"book":"Numbers","chapter":5,"exaltation":0,"peace":3,"admonition":6,"contrition":2,"dominant":"admonition","rationale":"Laws concerning uncleanness, restitution, and the trial of jealousy emphasize holiness and accountability."},
    {"book":"Numbers","chapter":6,"exaltation":6,"peace":7,"admonition":1,"contrition":0,"dominant":"peace","rationale":"The Nazirite vow of consecration and the Aaronic blessing bestow a sense of divine favor and peace."},
    {"book":"Numbers","chapter":7,"exaltation":5,"peace":8,"admonition":0,"contrition":0,"dominant":"peace","rationale":"The twelve tribal leaders bring their offerings for the dedication of the altar in a spirit of unified devotion."},
    {"book":"Numbers","chapter":8,"exaltation":4,"peace":7,"admonition":0,"contrition":0,"dominant":"peace","rationale":"The purification and dedication of the Levites for their service, along with the lighting of the lampstand."},
    {"book":"Numbers","chapter":9,"exaltation":3,"peace":6,"admonition":1,"contrition":0,"dominant":"peace","rationale":"Israel keeps the Passover in the wilderness; God guides them by the pillar of cloud and fire."},
    {"book":"Numbers","chapter":10,"exaltation":4,"peace":5,"admonition":0,"contrition":0,"dominant":"peace","rationale":"The silver trumpets are made and Israel departs Sinai in ordered march with the ark going before them."},
    {"book":"Numbers","chapter":11,"exaltation":1,"peace":1,"admonition":7,"contrition":4,"dominant":"admonition","rationale":"The people complain, fire from the LORD burns among them; they crave meat and are struck with a plague at Kibroth-hattaavah."},
    {"book":"Numbers","chapter":12,"exaltation":1,"peace":2,"admonition":7,"contrition":3,"dominant":"admonition","rationale":"Miriam and Aaron speak against Moses; God rebukes them, and Miriam is struck with leprosy for seven days."},
    {"book":"Numbers","chapter":13,"exaltation":1,"peace":2,"admonition":5,"contrition":4,"dominant":"admonition","rationale":"The twelve spies explore Canaan; ten bring a fearful report that demoralizes the congregation."},
    {"book":"Numbers","chapter":14,"exaltation":1,"peace":1,"admonition":8,"contrition":6,"dominant":"admonition","rationale":"Israel rebels and wishes to return to Egypt; God condemns the generation to forty years of wandering."},
    {"book":"Numbers","chapter":15,"exaltation":2,"peace":5,"admonition":4,"contrition":1,"dominant":"peace","rationale":"Laws for offerings in the promised land, the Sabbath-breaker stoned, and the commandment for fringes as reminders."},
    {"book":"Numbers","chapter":16,"exaltation":2,"peace":0,"admonition":9,"contrition":5,"dominant":"admonition","rationale":"Korah, Dathan, and Abiram rebel against Moses and Aaron; the earth swallows them and fire consumes 250 men."},
    {"book":"Numbers","chapter":17,"exaltation":4,"peace":5,"admonition":3,"contrition":2,"dominant":"peace","rationale":"Aaron's rod buds, blossoms, and bears almonds, confirming God's choice of the Levitical priesthood."},
    {"book":"Numbers","chapter":18,"exaltation":3,"peace":6,"admonition":2,"contrition":0,"dominant":"peace","rationale":"God establishes the duties and provisions for priests and Levites, including tithes and offerings."},
    {"book":"Numbers","chapter":19,"exaltation":1,"peace":5,"admonition":3,"contrition":1,"dominant":"peace","rationale":"The ordinance of the red heifer provides purification from defilement by contact with the dead."},
    {"book":"Numbers","chapter":20,"exaltation":1,"peace":2,"admonition":7,"contrition":5,"dominant":"admonition","rationale":"Miriam dies; Moses strikes the rock in anger and is told he will not enter the promised land; Aaron dies on Mount Hor."},
    {"book":"Numbers","chapter":21,"exaltation":3,"peace":3,"admonition":5,"contrition":3,"dominant":"admonition","rationale":"Fiery serpents punish murmuring Israel; the bronze serpent brings healing; Israel begins conquering lands east of Jordan."},
    {"book":"Numbers","chapter":22,"exaltation":2,"peace":3,"admonition":5,"contrition":2,"dominant":"admonition","rationale":"Balak summons Balaam to curse Israel; God warns Balaam, and his donkey sees the angel and speaks."},
    {"book":"Numbers","chapter":23,"exaltation":7,"peace":6,"admonition":1,"contrition":0,"dominant":"exaltation","rationale":"Balaam delivers two oracles of blessing upon Israel, declaring God has not cursed them and sees no iniquity in Jacob."},
    {"book":"Numbers","chapter":24,"exaltation":8,"peace":6,"admonition":1,"contrition":0,"dominant":"exaltation","rationale":"Balaam pronounces two more blessings and a messianic prophecy of a Star out of Jacob and a Sceptre out of Israel."},
    {"book":"Numbers","chapter":25,"exaltation":1,"peace":1,"admonition":8,"contrition":5,"dominant":"admonition","rationale":"Israel sins with Moabite women at Baal-peor; a plague kills 24,000 until Phinehas executes judgment with his zeal."},
    {"book":"Numbers","chapter":26,"exaltation":2,"peace":6,"admonition":1,"contrition":0,"dominant":"peace","rationale":"A second census of the new generation prepares Israel for the division of the promised land."},
    {"book":"Numbers","chapter":27,"exaltation":3,"peace":6,"admonition":1,"contrition":0,"dominant":"peace","rationale":"The daughters of Zelophehad receive an inheritance ruling; Joshua is commissioned as Moses' successor."},
    {"book":"Numbers","chapter":28,"exaltation":4,"peace":7,"admonition":0,"contrition":0,"dominant":"peace","rationale":"Detailed instructions for daily, Sabbath, monthly, and Passover offerings establish a rhythm of worship."},
    {"book":"Numbers","chapter":29,"exaltation":4,"peace":7,"admonition":0,"contrition":0,"dominant":"peace","rationale":"Offerings for the Feast of Trumpets, Day of Atonement, and Feast of Tabernacles emphasize joyful devotion."},
    {"book":"Numbers","chapter":30,"exaltation":1,"peace":5,"admonition":2,"contrition":0,"dominant":"peace","rationale":"Laws governing vows, especially those made by women, emphasize the sanctity of one's word before God."},
    {"book":"Numbers","chapter":31,"exaltation":3,"peace":2,"admonition":6,"contrition":1,"dominant":"admonition","rationale":"Israel wages war against Midian to avenge the sin of Baal-peor; spoil is divided and purified."},
    {"book":"Numbers","chapter":32,"exaltation":2,"peace":5,"admonition":4,"contrition":0,"dominant":"peace","rationale":"Reuben and Gad request land east of Jordan; Moses agrees on condition they help conquer the promised land."},
    {"book":"Numbers","chapter":33,"exaltation":2,"peace":5,"admonition":3,"contrition":0,"dominant":"peace","rationale":"A travel log of Israel's journey from Egypt to the plains of Moab, with instructions to drive out Canaan's inhabitants."},
    {"book":"Numbers","chapter":34,"exaltation":2,"peace":6,"admonition":1,"contrition":0,"dominant":"peace","rationale":"God defines the precise boundaries of the promised land and names the leaders who will divide it."},
    {"book":"Numbers","chapter":35,"exaltation":1,"peace":5,"admonition":4,"contrition":1,"dominant":"peace","rationale":"Levitical cities and cities of refuge are established, along with laws distinguishing murder from manslaughter."},
    {"book":"Numbers","chapter":36,"exaltation":1,"peace":6,"admonition":1,"contrition":0,"dominant":"peace","rationale":"Laws ensure tribal inheritances stay intact through marriage within the tribe, closing the book with order and obedience."}
