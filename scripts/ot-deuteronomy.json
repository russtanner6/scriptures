  "sentiment": [
    {"book":"Deuteronomy","chapter":1,"exaltation":2,"peace":3,"admonition":5,"contrition":3,"dominant":"admonition","rationale":"Moses recounts Israel's rebellion at Kadesh-barnea and God's judgment that the faithless generation would not enter the promised land."},
    {"book":"Deuteronomy","chapter":2,"exaltation":3,"peace":4,"admonition":3,"contrition":1,"dominant":"peace","rationale":"Moses recounts the journey through the wilderness, noting God's provision and the victories over Sihon as evidence of divine faithfulness."},
    {"book":"Deuteronomy","chapter":3,"exaltation":5,"peace":5,"admonition":2,"contrition":1,"dominant":"peace","rationale":"Victory over Og and the division of the land east of Jordan demonstrate God's power and covenant fulfillment."},
    {"book":"Deuteronomy","chapter":4,"exaltation":6,"peace":4,"admonition":7,"contrition":3,"dominant":"admonition","rationale":"A solemn charge to obey God's statutes, warnings against idolatry, and testimony of God's unique greatness among all nations."},
    {"book":"Deuteronomy","chapter":5,"exaltation":5,"peace":5,"admonition":7,"contrition":2,"dominant":"admonition","rationale":"Moses restates the Ten Commandments and warns Israel to walk in all the ways the Lord has commanded."},
    {"book":"Deuteronomy","chapter":6,"exaltation":7,"peace":6,"admonition":5,"contrition":1,"dominant":"exaltation","rationale":"Contains the Shema and the great commandment to love God with all heart, soul, and might—a pinnacle of devotion."},
    {"book":"Deuteronomy","chapter":7,"exaltation":6,"peace":5,"admonition":6,"contrition":1,"dominant":"exaltation","rationale":"God's choice of Israel as a special people, with warnings to destroy idolatry and promises of blessing for obedience."},
    {"book":"Deuteronomy","chapter":8,"exaltation":4,"peace":5,"admonition":7,"contrition":2,"dominant":"admonition","rationale":"A warning not to forget God in prosperity, remembering the wilderness discipline and divine provision."},
    {"book":"Deuteronomy","chapter":9,"exaltation":1,"peace":2,"admonition":7,"contrition":7,"dominant":"admonition","rationale":"Moses reminds Israel of their repeated rebellions—the golden calf, Taberah, Massah—showing they did not earn God's favor."},
    {"book":"Deuteronomy","chapter":10,"exaltation":6,"peace":6,"admonition":4,"contrition":2,"dominant":"exaltation","rationale":"God's mercy in renewing the tablets and his call to circumcise the heart, love the stranger, and serve him."},
    {"book":"Deuteronomy","chapter":11,"exaltation":5,"peace":5,"admonition":6,"contrition":2,"dominant":"admonition","rationale":"A charge to love and obey, with blessings and curses set before Israel as they prepare to enter the land."},
    {"book":"Deuteronomy","chapter":12,"exaltation":3,"peace":5,"admonition":6,"contrition":1,"dominant":"admonition","rationale":"Instructions to destroy pagan worship sites and worship only at the place the Lord chooses."},
    {"book":"Deuteronomy","chapter":13,"exaltation":1,"peace":2,"admonition":9,"contrition":2,"dominant":"admonition","rationale":"Severe warnings against false prophets and enticers to idolatry, requiring the death penalty to purge evil."},
    {"book":"Deuteronomy","chapter":14,"exaltation":2,"peace":5,"admonition":4,"contrition":1,"dominant":"peace","rationale":"Laws on clean and unclean foods and tithing, establishing Israel's identity as a holy people set apart."},
    {"book":"Deuteronomy","chapter":15,"exaltation":3,"peace":7,"admonition":3,"contrition":1,"dominant":"peace","rationale":"Laws of release for debts and slaves, emphasizing generosity and compassion toward the poor."},
    {"book":"Deuteronomy","chapter":16,"exaltation":5,"peace":6,"admonition":4,"contrition":1,"dominant":"peace","rationale":"Instructions for the three pilgrimage feasts (Passover, Weeks, Tabernacles) and the appointment of just judges."},
    {"book":"Deuteronomy","chapter":17,"exaltation":2,"peace":4,"admonition":7,"contrition":1,"dominant":"admonition","rationale":"Laws for judicial cases, warnings against idolatry, and the law of the king—requiring humility and Torah study."},
    {"book":"Deuteronomy","chapter":18,"exaltation":6,"peace":5,"admonition":5,"contrition":1,"dominant":"exaltation","rationale":"Priestly provisions, prohibition of occult practices, and the great Messianic prophecy of a Prophet like Moses."},
    {"book":"Deuteronomy","chapter":19,"exaltation":1,"peace":5,"admonition":6,"contrition":1,"dominant":"admonition","rationale":"Cities of refuge for manslayers, laws against moving boundary stones, and rules for witnesses."},
    {"book":"Deuteronomy","chapter":20,"exaltation":3,"peace":4,"admonition":5,"contrition":1,"dominant":"admonition","rationale":"Laws of warfare, including exemptions from battle and rules for sieges and the treatment of conquered cities."},
    {"book":"Deuteronomy","chapter":21,"exaltation":1,"peace":3,"admonition":6,"contrition":3,"dominant":"admonition","rationale":"Laws for unsolved murders, captive women, firstborn rights, and rebellious sons—emphasizing justice and order."},
    {"book":"Deuteronomy","chapter":22,"exaltation":1,"peace":3,"admonition":7,"contrition":2,"dominant":"admonition","rationale":"Miscellaneous laws on lost property, gender distinction, building codes, and sexual morality."},
    {"book":"Deuteronomy","chapter":23,"exaltation":2,"peace":4,"admonition":6,"contrition":1,"dominant":"admonition","rationale":"Laws about who may enter the assembly, camp hygiene, escaped slaves, vows, and usury."},
    {"book":"Deuteronomy","chapter":24,"exaltation":1,"peace":5,"admonition":5,"contrition":2,"dominant":"admonition","rationale":"Laws on divorce, pledges, wages, and gleaning—protecting the vulnerable and requiring compassion."},
    {"book":"Deuteronomy","chapter":25,"exaltation":1,"peace":3,"admonition":6,"contrition":2,"dominant":"admonition","rationale":"Laws on judicial punishment, levirate marriage, honest weights, and the command to blot out Amalek."},
    {"book":"Deuteronomy","chapter":26,"exaltation":6,"peace":7,"admonition":2,"contrition":1,"dominant":"peace","rationale":"The firstfruits ceremony and tithing declaration—Israel affirms God as their God and he affirms them as his people."},
    {"book":"Deuteronomy","chapter":27,"exaltation":2,"peace":2,"admonition":8,"contrition":3,"dominant":"admonition","rationale":"The covenant ceremony at Ebal and Gerizim with twelve curses pronounced upon specific transgressions."},
    {"book":"Deuteronomy","chapter":28,"exaltation":5,"peace":5,"admonition":9,"contrition":5,"dominant":"admonition","rationale":"The blessings for obedience and extensive curses for disobedience—one of the most consequential chapters in Torah."},
    {"book":"Deuteronomy","chapter":29,"exaltation":3,"peace":4,"admonition":7,"contrition":4,"dominant":"admonition","rationale":"Covenant renewal in Moab with warnings of the devastating consequences of forsaking the Lord."},
    {"book":"Deuteronomy","chapter":30,"exaltation":6,"peace":7,"admonition":4,"contrition":3,"dominant":"peace","rationale":"Promise of restoration after repentance and the stirring call to choose life and blessing."},
    {"book":"Deuteronomy","chapter":31,"exaltation":4,"peace":4,"admonition":6,"contrition":3,"dominant":"admonition","rationale":"Moses commissions Joshua, warns of future apostasy, and commands the reading of the law."},
    {"book":"Deuteronomy","chapter":32,"exaltation":7,"peace":3,"admonition":8,"contrition":5,"dominant":"admonition","rationale":"The Song of Moses—a sweeping prophetic poem of God's faithfulness contrasted with Israel's ingratitude and coming judgment."},
    {"book":"Deuteronomy","chapter":33,"exaltation":9,"peace":8,"admonition":1,"contrition":0,"dominant":"exaltation","rationale":"Moses' final blessing upon each tribe, filled with praise for God's majesty and promises of divine protection."},
    {"book":"Deuteronomy","chapter":34,"exaltation":6,"peace":7,"admonition":1,"contrition":3,"dominant":"peace","rationale":"The death of Moses on Mount Nebo, the mourning of Israel, and the transition of leadership to Joshua."}
