    {"book":"Deuteronomy","chapter":8,"verses":[{"verse":3,"reason":"Man doth not live by bread only, but by every word of the Lord—quoted by Jesus."}]},
    {"book":"Deuteronomy","chapter":9,"verses":[{"verse":4,"reason":"Warning not to assume righteousness earned God's favor; he acts for his own purposes."}]},
    {"book":"Deuteronomy","chapter":10,"verses":[{"verse":12,"reason":"What doth the Lord require but to fear him, walk in his ways, love and serve him."}]},
    {"book":"Deuteronomy","chapter":11,"verses":[{"verse":26,"reason":"Moses sets before Israel a blessing and a curse—obedience or disobedience."}]},
    {"book":"Deuteronomy","chapter":12,"verses":[{"verse":32,"reason":"Command not to add to or diminish from what the Lord has commanded."}]},
    {"book":"Deuteronomy","chapter":13,"verses":[{"verse":3,"reason":"False signs test whether you love the Lord with all your heart and soul."}]},
    {"book":"Deuteronomy","chapter":14,"verses":[]},
    {"book":"Deuteronomy","chapter":15,"verses":[{"verse":11,"reason":"The poor shall never cease out of the land; therefore open thine hand wide."}]},
    {"book":"Deuteronomy","chapter":16,"verses":[{"verse":20,"reason":"That which is altogether just shalt thou follow, that thou mayest live."}]},
    {"book":"Deuteronomy","chapter":17,"verses":[{"verse":19,"reason":"The future king must read the law all the days of his life, to keep his heart humble."}]},
    {"book":"Deuteronomy","chapter":18,"verses":[{"verse":15,"reason":"Messianic prophecy: God will raise up a Prophet like Moses from among the brethren."}]},
    {"book":"Deuteronomy","chapter":19,"verses":[{"verse":15,"reason":"Establishes the principle that testimony requires two or three witnesses."}]},
    {"book":"Deuteronomy","chapter":20,"verses":[{"verse":4,"reason":"The Lord your God goeth with you, to fight for you against your enemies."}]},
