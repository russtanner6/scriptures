{
  "bookName": "2 Samuel",
  "bookId": 10,
  "sentiment": [
    {"book":"2 Samuel","chapter":1,"exaltation":2,"peace":1,"admonition":4,"contrition":8,"dominant":"contrition","rationale":"David mourns Saul and Jonathan with a deeply sorrowful lament over the fallen heroes of Israel."},
    {"book":"2 Samuel","chapter":2,"exaltation":3,"peace":2,"admonition":6,"contrition":3,"dominant":"admonition","rationale":"Civil war erupts between the house of Saul and the house of David, with the death of Asahel."},
    {"book":"2 Samuel","chapter":3,"exaltation":3,"peace":3,"admonition":7,"contrition":5,"dominant":"admonition","rationale":"Abner defects to David but is murdered by Joab; David mourns Abner and curses Joab's house."},
    {"book":"2 Samuel","chapter":4,"exaltation":1,"peace":1,"admonition":8,"contrition":3,"dominant":"admonition","rationale":"Ish-bosheth is assassinated; David executes the murderers for slaying a righteous man."},
    {"book":"2 Samuel","chapter":5,"exaltation":8,"peace":6,"admonition":0,"contrition":0,"dominant":"exaltation","rationale":"David is anointed king over all Israel, captures Jerusalem, and defeats the Philistines with divine guidance."},
    {"book":"2 Samuel","chapter":6,"exaltation":8,"peace":5,"admonition":3,"contrition":1,"dominant":"exaltation","rationale":"The Ark is brought to Jerusalem with great celebration, though Uzzah is struck and Michal despises David."},
    {"book":"2 Samuel","chapter":7,"exaltation":8,"peace":9,"admonition":0,"contrition":0,"dominant":"peace","rationale":"God establishes the Davidic Covenant through Nathan, and David responds with a humble prayer of gratitude."},
    {"book":"2 Samuel","chapter":8,"exaltation":7,"peace":5,"admonition":0,"contrition":0,"dominant":"exaltation","rationale":"David's military victories over surrounding nations and the expansion of his kingdom under divine favor."},
    {"book":"2 Samuel","chapter":9,"exaltation":2,"peace":8,"admonition":0,"contrition":0,"dominant":"peace","rationale":"David shows covenant kindness to Mephibosheth, Jonathan's son, restoring Saul's land and inviting him to the king's table."},
    {"book":"2 Samuel","chapter":10,"exaltation":4,"peace":1,"admonition":5,"contrition":0,"dominant":"admonition","rationale":"The Ammonites insult David's ambassadors, leading to war and the defeat of Ammon and their Syrian allies."},
    {"book":"2 Samuel","chapter":11,"exaltation":0,"peace":0,"admonition":9,"contrition":3,"dominant":"admonition","rationale":"David commits adultery with Bathsheba and arranges the death of Uriah—a profound moral failure."},
    {"book":"2 Samuel","chapter":12,"exaltation":2,"peace":2,"admonition":8,"contrition":7,"dominant":"admonition","rationale":"Nathan confronts David with the parable of the ewe lamb; the child dies, but Solomon is born."},
    {"book":"2 Samuel","chapter":13,"exaltation":0,"peace":0,"admonition":8,"contrition":7,"dominant":"admonition","rationale":"Amnon violates Tamar, Absalom avenges her by killing Amnon, and flees into exile."},
    {"book":"2 Samuel","chapter":14,"exaltation":1,"peace":3,"admonition":5,"contrition":3,"dominant":"admonition","rationale":"Joab uses the wise woman of Tekoa to persuade David to allow Absalom to return from exile."},
    {"book":"2 Samuel","chapter":15,"exaltation":1,"peace":2,"admonition":6,"contrition":6,"dominant":"contrition","rationale":"Absalom conspires to steal the kingdom; David flees Jerusalem weeping in deep sorrow and humility."},
    {"book":"2 Samuel","chapter":16,"exaltation":0,"peace":1,"admonition":7,"contrition":5,"dominant":"admonition","rationale":"Shimei curses David, Ziba deceives him, and Absalom enters Jerusalem following Ahithophel's counsel."},
    {"book":"2 Samuel","chapter":17,"exaltation":1,"peace":2,"admonition":6,"contrition":2,"dominant":"admonition","rationale":"Hushai overthrows Ahithophel's counsel, saving David; Ahithophel takes his own life."},
    {"book":"2 Samuel","chapter":18,"exaltation":1,"peace":1,"admonition":5,"contrition":8,"dominant":"contrition","rationale":"Absalom is killed by Joab; David's grief-stricken cry for his son is one of scripture's most poignant moments."},
    {"book":"2 Samuel","chapter":19,"exaltation":2,"peace":5,"admonition":3,"contrition":3,"dominant":"peace","rationale":"David returns to Jerusalem, pardons Shimei, and settles disputes among his supporters in a spirit of restoration."},
    {"book":"2 Samuel","chapter":20,"exaltation":1,"peace":2,"admonition":7,"contrition":1,"dominant":"admonition","rationale":"Sheba's rebellion against David is put down by Joab, ending with the wise woman of Abel saving her city."},
    {"book":"2 Samuel","chapter":21,"exaltation":2,"peace":3,"admonition":6,"contrition":4,"dominant":"admonition","rationale":"A famine from Saul's bloodguilt against the Gibeonites is resolved through justice, followed by wars with Philistine giants."},
    {"book":"2 Samuel","chapter":22,"exaltation":10,"peace":7,"admonition":2,"contrition":1,"dominant":"exaltation","rationale":"David's great psalm of deliverance, praising God as his rock, fortress, and deliverer from all enemies."},
    {"book":"2 Samuel","chapter":23,"exaltation":6,"peace":5,"admonition":1,"contrition":0,"dominant":"exaltation","rationale":"David's last words and the roll call of his mighty men and their legendary deeds of valor."},
    {"book":"2 Samuel","chapter":24,"exaltation":2,"peace":4,"admonition":7,"contrition":6,"dominant":"admonition","rationale":"David numbers the people, a plague comes as judgment, and he purchases Araunah's threshingfloor for sacrifice."}
