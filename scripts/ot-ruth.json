  "summaries": [
    {"book":"Ruth","chapter":1,"summary":"Naomi, widowed and bereaved of her sons in Moab, returns to Bethlehem; Ruth pledges her undying loyalty and accompanies her, while Orpah turns back."},
    {"book":"Ruth","chapter":2,"summary":"Ruth gleans in the field of Boaz, a kinsman of Naomi's husband; Boaz shows her extraordinary kindness and protection, and Naomi recognizes God's providence."},
    {"book":"Ruth","chapter":3,"summary":"Following Naomi's instructions, Ruth approaches Boaz at the threshing floor and asks him to act as her kinsman-redeemer; he agrees, pending a nearer kinsman's decision."},
    {"book":"Ruth","chapter":4,"summary":"Boaz secures the right of redemption at the city gate, marries Ruth, and their son Obed becomes the grandfather of King David."}
