  "sentiment": [
    {"book":"1 Samuel","chapter":1,"exaltation":2,"peace":5,"admonition":1,"contrition":6,"dominant":"contrition","rationale":"Hannah's deep anguish and tearful prayer for a child, followed by the peace of God's answer through Eli."},
    {"book":"1 Samuel","chapter":2,"exaltation":8,"peace":5,"admonition":6,"contrition":2,"dominant":"exaltation","rationale":"Hannah's song of praise exalts God's power and sovereignty, contrasted with the judgment pronounced on Eli's wicked sons."},
    {"book":"1 Samuel","chapter":3,"exaltation":3,"peace":4,"admonition":8,"contrition":2,"dominant":"admonition","rationale":"The Lord's call to Samuel includes a stern prophecy of judgment against the house of Eli for the iniquity of his sons."},
    {"book":"1 Samuel","chapter":4,"exaltation":0,"peace":0,"admonition":6,"contrition":9,"dominant":"contrition","rationale":"Israel is defeated, the Ark captured, and Eli and his sons die—a chapter of catastrophic loss and grief."},
    {"book":"1 Samuel","chapter":5,"exaltation":0,"peace":0,"admonition":9,"contrition":5,"dominant":"admonition","rationale":"The Ark of God brings plagues upon the Philistines and destroys the idol Dagon—a display of divine judgment."},
    {"book":"1 Samuel","chapter":6,"exaltation":2,"peace":4,"admonition":6,"contrition":3,"dominant":"admonition","rationale":"The Philistines return the Ark with guilt offerings, but men of Beth-shemesh are struck for looking into it."},
    {"book":"1 Samuel","chapter":7,"exaltation":6,"peace":7,"admonition":2,"contrition":3,"dominant":"peace","rationale":"Samuel leads Israel to repentance and prayer; God thunders against the Philistines and grants peace."},
    {"book":"1 Samuel","chapter":8,"exaltation":0,"peace":2,"admonition":8,"contrition":3,"dominant":"admonition","rationale":"Israel rejects God as king by demanding a human monarch; Samuel warns of the consequences of this choice."},
    {"book":"1 Samuel","chapter":9,"exaltation":3,"peace":6,"admonition":0,"contrition":0,"dominant":"peace","rationale":"Saul is providentially led to Samuel, who anoints him privately as the chosen leader of Israel."},
    {"book":"1 Samuel","chapter":10,"exaltation":6,"peace":5,"admonition":1,"contrition":0,"dominant":"exaltation","rationale":"Saul is publicly chosen as king; the Spirit of God comes upon him and he prophesies among the prophets."},
    {"book":"1 Samuel","chapter":11,"exaltation":7,"peace":5,"admonition":1,"contrition":0,"dominant":"exaltation","rationale":"Saul's first military victory over the Ammonites at Jabesh-gilead, followed by his confirmation as king."},
    {"book":"1 Samuel","chapter":12,"exaltation":3,"peace":4,"admonition":8,"contrition":3,"dominant":"admonition","rationale":"Samuel's farewell address warns Israel of the consequences of wickedness while affirming God's faithfulness."},
    {"book":"1 Samuel","chapter":13,"exaltation":0,"peace":0,"admonition":9,"contrition":4,"dominant":"admonition","rationale":"Saul's unlawful sacrifice leads to Samuel's rebuke and the prophecy that his kingdom will not endure."},
    {"book":"1 Samuel","chapter":14,"exaltation":6,"peace":3,"admonition":5,"contrition":2,"dominant":"exaltation","rationale":"Jonathan's faith-driven attack on the Philistines brings a great victory, but Saul's rash oath creates conflict."},
    {"book":"1 Samuel","chapter":15,"exaltation":0,"peace":0,"admonition":10,"contrition":5,"dominant":"admonition","rationale":"Saul's disobedience in sparing Agag leads to his rejection as king—'to obey is better than sacrifice.'"},
    {"book":"1 Samuel","chapter":16,"exaltation":6,"peace":5,"admonition":2,"contrition":1,"dominant":"exaltation","rationale":"David is anointed by Samuel as God's chosen king; the Spirit of the Lord comes upon David."},
    {"book":"1 Samuel","chapter":17,"exaltation":9,"peace":3,"admonition":2,"contrition":0,"dominant":"exaltation","rationale":"David's faith-filled victory over Goliath demonstrates trust in God over human strength and armor."},
    {"book":"1 Samuel","chapter":18,"exaltation":4,"peace":4,"admonition":4,"contrition":2,"dominant":"admonition","rationale":"David's rise in popularity provokes Saul's jealousy and murderous intent, though Jonathan's friendship endures."},
    {"book":"1 Samuel","chapter":19,"exaltation":2,"peace":2,"admonition":6,"contrition":3,"dominant":"admonition","rationale":"Saul repeatedly attempts to kill David; Michal and Jonathan help David escape. Saul prophesies despite his hostility."},
    {"book":"1 Samuel","chapter":20,"exaltation":1,"peace":6,"admonition":4,"contrition":5,"dominant":"peace","rationale":"The covenant of friendship between David and Jonathan, marked by deep loyalty and sorrowful parting."},
    {"book":"1 Samuel","chapter":21,"exaltation":0,"peace":2,"admonition":3,"contrition":5,"dominant":"contrition","rationale":"David flees to Nob and then to Gath, resorting to deception out of fear and desperation."},
    {"book":"1 Samuel","chapter":22,"exaltation":1,"peace":1,"admonition":8,"contrition":7,"dominant":"admonition","rationale":"Saul orders the massacre of the priests of Nob—one of the darkest acts of his reign."},
    {"book":"1 Samuel","chapter":23,"exaltation":3,"peace":4,"admonition":4,"contrition":3,"dominant":"admonition","rationale":"David saves Keilah but is hunted by Saul; Jonathan strengthens David's hand in God."},
    {"book":"1 Samuel","chapter":24,"exaltation":3,"peace":6,"admonition":3,"contrition":4,"dominant":"peace","rationale":"David spares Saul's life in the cave at En-gedi, showing restraint and reverence for God's anointed."},
    {"book":"1 Samuel","chapter":25,"exaltation":3,"peace":5,"admonition":5,"contrition":3,"dominant":"admonition","rationale":"Nabal's foolish refusal and Abigail's wise intervention prevent David from taking vengeance; God strikes Nabal."},
    {"book":"1 Samuel","chapter":26,"exaltation":3,"peace":5,"admonition":3,"contrition":3,"dominant":"peace","rationale":"David again spares Saul's life, taking only his spear and water; Saul briefly acknowledges his sin."},
    {"book":"1 Samuel","chapter":27,"exaltation":0,"peace":3,"admonition":3,"contrition":3,"dominant":"contrition","rationale":"David seeks refuge among the Philistines at Ziklag, living by deception to survive Saul's persecution."},
    {"book":"1 Samuel","chapter":28,"exaltation":0,"peace":0,"admonition":8,"contrition":8,"dominant":"admonition","rationale":"Saul consults the witch of Endor in desperation; Samuel's spirit delivers a final, devastating prophecy."},
    {"book":"1 Samuel","chapter":29,"exaltation":0,"peace":4,"admonition":2,"contrition":2,"dominant":"peace","rationale":"David is providentially sent away from the Philistine battle against Israel by the suspicious lords."},
    {"book":"1 Samuel","chapter":30,"exaltation":5,"peace":5,"admonition":3,"contrition":4,"dominant":"peace","rationale":"David recovers all from the Amalekite raid on Ziklag after inquiring of the Lord, and shares the spoil."},
