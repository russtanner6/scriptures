  "summaries": [
    {"book":"1 Samuel","chapter":1,"summary":"Hannah, barren and grieving, prays fervently at the tabernacle and vows to dedicate her son to the Lord; Eli blesses her, and she bears Samuel."},
    {"book":"1 Samuel","chapter":2,"summary":"Hannah offers a prophetic song of praise; Eli's wicked sons abuse their priestly office, and a man of God prophesies judgment on Eli's house."},
    {"book":"1 Samuel","chapter":3,"summary":"The Lord calls young Samuel in the night and reveals the coming judgment against Eli's family; Samuel is established as a prophet in Israel."},
    {"book":"1 Samuel","chapter":4,"summary":"Israel is defeated by the Philistines, the Ark of the Covenant is captured, and Eli and his sons Hophni and Phinehas die."},
    {"book":"1 Samuel","chapter":5,"summary":"The Ark is placed in the temple of Dagon, which falls before it; the Lord afflicts the Philistines with tumors in every city that holds the Ark."},
    {"book":"1 Samuel","chapter":6,"summary":"The Philistines return the Ark to Israel on a new cart with guilt offerings; men of Beth-shemesh are struck for looking into it."},
    {"book":"1 Samuel","chapter":7,"summary":"Samuel calls Israel to repentance; they fast and pray at Mizpeh, and God delivers them from the Philistines with thunder."},
    {"book":"1 Samuel","chapter":8,"summary":"Israel demands a king like the other nations; Samuel warns them of the consequences, but the Lord instructs him to grant their request."},
    {"book":"1 Samuel","chapter":9,"summary":"Saul, searching for his father's lost donkeys, is led to Samuel, who privately anoints him as the future king of Israel."},
    {"book":"1 Samuel","chapter":10,"summary":"Samuel publicly presents Saul as king; the Spirit of God comes upon Saul and he prophesies among the prophets."},
    {"book":"1 Samuel","chapter":11,"summary":"Saul rallies Israel and defeats the Ammonites at Jabesh-gilead; the kingdom is renewed and Saul is confirmed as king at Gilgal."},
    {"book":"1 Samuel","chapter":12,"summary":"Samuel delivers his farewell address, testifying of his integrity, recounting God's deliverance, and warning Israel to serve the Lord faithfully."},
    {"book":"1 Samuel","chapter":13,"summary":"Saul unlawfully offers a sacrifice while waiting for Samuel; Samuel rebukes him and declares his kingdom will not continue."},
    {"book":"1 Samuel","chapter":14,"summary":"Jonathan and his armor-bearer rout a Philistine garrison by faith; Saul's rash oath nearly costs Jonathan's life."},
    {"book":"1 Samuel","chapter":15,"summary":"Saul disobeys God's command to utterly destroy Amalek; Samuel declares 'to obey is better than sacrifice' and announces Saul's rejection as king."},
    {"book":"1 Samuel","chapter":16,"summary":"Samuel anoints David as king; the Spirit of the Lord comes upon David, while an evil spirit troubles Saul, who summons David as a musician."},
    {"book":"1 Samuel","chapter":17,"summary":"David, a young shepherd, defeats the Philistine giant Goliath with a sling and a stone, trusting in the name of the Lord."},
    {"book":"1 Samuel","chapter":18,"summary":"David and Jonathan form a covenant of friendship; David's military successes provoke Saul's jealousy, and Saul attempts to kill him."},
    {"book":"1 Samuel","chapter":19,"summary":"Saul seeks to kill David; Jonathan intercedes, Michal helps David escape, and Saul himself prophesies at Naioth in Ramah."},
    {"book":"1 Samuel","chapter":20,"summary":"Jonathan and David make a covenant of friendship; Jonathan warns David of Saul's intent to kill him, and they part in sorrow."},
    {"book":"1 Samuel","chapter":21,"summary":"David flees to Nob where Ahimelech gives him the showbread and Goliath's sword, then escapes to Achish king of Gath."},
    {"book":"1 Samuel","chapter":22,"summary":"David gathers a following at the cave of Adullam; Saul orders Doeg to massacre the priests of Nob for helping David."},
    {"book":"1 Samuel","chapter":23,"summary":"David saves Keilah from the Philistines; Saul pursues David in the wilderness, but Jonathan strengthens David's faith in God."},
    {"book":"1 Samuel","chapter":24,"summary":"David spares Saul's life in the cave at En-gedi, cutting only his robe; Saul weeps and acknowledges David's righteousness."},
    {"book":"1 Samuel","chapter":25,"summary":"Nabal insults David's men; Abigail intervenes with wisdom and provisions, preventing bloodshed; Nabal dies and David marries Abigail."},
    {"book":"1 Samuel","chapter":26,"summary":"David again spares Saul's life, taking his spear and water jug; Saul confesses his error and blesses David."},
    {"book":"1 Samuel","chapter":27,"summary":"David escapes to Philistine territory and lives at Ziklag under Achish, raiding Israel's enemies while deceiving Achish about his targets."},
    {"book":"1 Samuel","chapter":28,"summary":"Saul, terrified before battle, consults the medium at Endor; Samuel's spirit foretells Saul's defeat and death."},
    {"book":"1 Samuel","chapter":29,"summary":"The Philistine lords distrust David and send him away from the battle against Israel; Achish dismisses him reluctantly."},
    {"book":"1 Samuel","chapter":30,"summary":"David pursues and defeats the Amalekites who raided Ziklag, recovering all captives and spoil, and establishes a law for dividing plunder."},
    {"book":"1 Samuel","chapter":31,"summary":"Saul and his three sons are killed in battle against the Philistines on Mount Gilboa; the men of Jabesh-gilead recover their bodies."}
