  "crossReferences": [
    {"book":"1 Samuel","chapter":2,"verse":10,"crossReference":"Luke 1:46-55","type":"parallel","note":"Hannah's song of praise closely parallels Mary's Magnificat in its themes of divine reversal and exaltation of the humble."},
    {"book":"1 Samuel","chapter":8,"verse":7,"crossReference":"Mosiah 29:21-23","type":"parallel","note":"Both passages warn of the dangers when a people rejects divine governance in favor of earthly kingship."},
    {"book":"1 Samuel","chapter":15,"verse":22,"crossReference":"Hosea 6:6","type":"parallel","note":"Both emphasize that God desires obedience and mercy over ritual sacrifice."},
    {"book":"1 Samuel","chapter":16,"verse":7,"crossReference":"John 7:24","type":"parallel","note":"Both teach that God judges by the heart, not by outward appearance."},
    {"book":"1 Samuel","chapter":17,"verse":47,"crossReference":"2 Chronicles 20:15","type":"parallel","note":"Both declare that the battle is the Lord's, not man's."},
    {"book":"1 Samuel","chapter":21,"verse":6,"crossReference":"Matthew 12:3-4","type":"fulfillment","note":"Jesus cites David eating the showbread as a precedent for mercy over rigid law observance."},
    {"book":"1 Samuel","chapter":24,"verse":6,"crossReference":"Psalm 105:15","type":"allusion","note":"David's refusal to harm the Lord's anointed reflects the principle taught in Psalms."},
    {"book":"1 Samuel","chapter":28,"verse":19,"crossReference":"1 Chronicles 10:13-14","type":"parallel","note":"Chronicles interprets Saul's death as divine judgment for consulting a medium instead of the Lord."}
