    {"book":"2 Chronicles","chapter":13,"exaltation":7,"peace":4,"admonition":5,"contrition":0,"dominant":"exaltation","rationale":"Abijah rebukes Jeroboam's apostasy and wins a decisive battle through trust in God."},
    {"book":"2 Chronicles","chapter":14,"exaltation":6,"peace":6,"admonition":0,"contrition":1,"dominant":"exaltation","rationale":"Asa's faithful reign and his prayer before the Ethiopian army, resulting in divine deliverance."},
    {"book":"2 Chronicles","chapter":15,"exaltation":5,"peace":7,"admonition":4,"contrition":0,"dominant":"peace","rationale":"The prophet Azariah encourages Asa; Judah renews the covenant and seeks the Lord with all their heart."},
    {"book":"2 Chronicles","chapter":16,"exaltation":0,"peace":2,"admonition":8,"contrition":2,"dominant":"admonition","rationale":"Asa relies on Syria instead of God; the seer Hanani rebukes him; Asa ends his reign in disobedience."},
    {"book":"2 Chronicles","chapter":17,"exaltation":6,"peace":7,"admonition":0,"contrition":0,"dominant":"peace","rationale":"Jehoshaphat walks in the ways of David, sends teachers throughout Judah, and the kingdom prospers."},
    {"book":"2 Chronicles","chapter":18,"exaltation":0,"peace":1,"admonition":8,"contrition":2,"dominant":"admonition","rationale":"Jehoshaphat's ill-advised alliance with Ahab; Micaiah prophesies judgment; Ahab is slain."},
    {"book":"2 Chronicles","chapter":19,"exaltation":3,"peace":6,"admonition":4,"contrition":0,"dominant":"peace","rationale":"Jehoshaphat is rebuked by Jehu but reforms the judiciary and charges judges to act in the fear of the Lord."},
