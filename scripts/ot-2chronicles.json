    {"book":"2 Chronicles","chapter":30,"exaltation":7,"peace":8,"admonition":1,"contrition":2,"dominant":"peace","rationale":"Hezekiah invites all Israel to a great Passover; God heals those who sought Him with imperfect ritual preparation."},
    {"book":"2 Chronicles","chapter":31,"exaltation":5,"peace":7,"admonition":0,"contrition":0,"dominant":"peace","rationale":"The people destroy idols across the land and generously provide for the Levites and priests."},
