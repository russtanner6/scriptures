    {"book":"2 Chronicles","chapter":26,"exaltation":5,"peace":4,"admonition":7,"contrition":2,"dominant":"admonition","rationale":"Uzziah prospers but presumptuously enters the temple to burn incense; is struck with leprosy."},
    {"book":"2 Chronicles","chapter":27,"exaltation":5,"peace":6,"admonition":0,"contrition":0,"dominant":"peace","rationale":"Jotham's righteous reign—he builds and prospers because he ordered his ways before the Lord."},
