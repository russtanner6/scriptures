    {"book":"2 Chronicles","chapter":21,"exaltation":0,"peace":0,"admonition":9,"contrition":4,"dominant":"admonition","rationale":"Jehoram's wicked reign, Elijah's letter of warning, and divine judgments through invasion and disease."},
    {"book":"2 Chronicles","chapter":22,"exaltation":0,"peace":0,"admonition":8,"contrition":3,"dominant":"admonition","rationale":"Ahaziah's brief wicked reign under Athaliah's influence; Jehu executes judgment; Athaliah usurps the throne."},
