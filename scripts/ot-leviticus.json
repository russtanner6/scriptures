  "sentiment": [
    {"book":"Leviticus","chapter":1,"exaltation":3,"peace":6,"admonition":2,"contrition":0,"dominant":"peace","rationale":"Instructions for burnt offerings given as a sweet savour unto the Lord, emphasizing voluntary devotion and acceptance."},
    {"book":"Leviticus","chapter":2,"exaltation":2,"peace":7,"admonition":1,"contrition":0,"dominant":"peace","rationale":"The meat (grain) offering regulations emphasize peace and consecration through offerings of fine flour, oil, and frankincense."},
    {"book":"Leviticus","chapter":3,"exaltation":2,"peace":8,"admonition":1,"contrition":0,"dominant":"peace","rationale":"Peace offerings are presented as a means of fellowship and covenant communion between God and His people."},
    {"book":"Leviticus","chapter":4,"exaltation":0,"peace":4,"admonition":5,"contrition":5,"dominant":"admonition","rationale":"The sin offering addresses unintentional transgressions, emphasizing the need for atonement and the seriousness of sin before God."},
    {"book":"Leviticus","chapter":5,"exaltation":0,"peace":3,"admonition":6,"contrition":6,"dominant":"contrition","rationale":"Trespass offerings deal with guilt and restitution, emphasizing accountability and the weight of personal sin."},
    {"book":"Leviticus","chapter":6,"exaltation":1,"peace":5,"admonition":4,"contrition":3,"dominant":"peace","rationale":"Priestly instructions for maintaining offerings, including the perpetual fire, blending sacred duty with accountability for sin."},
    {"book":"Leviticus","chapter":7,"exaltation":2,"peace":6,"admonition":4,"contrition":1,"dominant":"peace","rationale":"Laws for trespass and peace offerings including portions for priests, with warnings against eating fat or blood."},
    {"book":"Leviticus","chapter":8,"exaltation":7,"peace":7,"admonition":1,"contrition":0,"dominant":"exaltation","rationale":"The consecration of Aaron and his sons as priests is a high moment of divine appointment, anointing, and sacred investiture."},
    {"book":"Leviticus","chapter":9,"exaltation":9,"peace":6,"admonition":0,"contrition":0,"dominant":"exaltation","rationale":"The glory of the Lord appears to all the people and fire comes out from before the Lord, consuming the offering."},
    {"book":"Leviticus","chapter":10,"exaltation":0,"peace":2,"admonition":9,"contrition":5,"dominant":"admonition","rationale":"Nadab and Abihu offer strange fire and are consumed by divine fire, a severe warning about unauthorized worship."},
    {"book":"Leviticus","chapter":11,"exaltation":1,"peace":4,"admonition":5,"contrition":0,"dominant":"admonition","rationale":"Dietary laws distinguish clean from unclean animals, calling Israel to holiness and separation from defilement."},
    {"book":"Leviticus","chapter":12,"exaltation":0,"peace":5,"admonition":3,"contrition":1,"dominant":"peace","rationale":"Purification after childbirth, combining themes of ritual cleanness with restoration through offering."},
    {"book":"Leviticus","chapter":13,"exaltation":0,"peace":2,"admonition":7,"contrition":4,"dominant":"admonition","rationale":"Detailed examination of leprosy and skin diseases, with strict procedures for identification and isolation of the unclean."},
    {"book":"Leviticus","chapter":14,"exaltation":2,"peace":6,"admonition":3,"contrition":2,"dominant":"peace","rationale":"Cleansing rituals for the healed leper, emphasizing restoration, atonement, and reintegration into the community."},
    {"book":"Leviticus","chapter":15,"exaltation":0,"peace":4,"admonition":5,"contrition":2,"dominant":"admonition","rationale":"Laws regarding bodily discharges and their associated uncleanness, requiring purification and offerings for restoration."},
    {"book":"Leviticus","chapter":16,"exaltation":5,"peace":7,"admonition":4,"contrition":5,"dominant":"peace","rationale":"The Day of Atonement — the holiest ritual in Israel — combining deep contrition with the exalted promise of complete reconciliation."},
    {"book":"Leviticus","chapter":17,"exaltation":1,"peace":4,"admonition":7,"contrition":1,"dominant":"admonition","rationale":"Strict prohibitions against eating blood and unsanctioned sacrifices, emphasizing that the life of the flesh is in the blood."},
    {"book":"Leviticus","chapter":18,"exaltation":0,"peace":2,"admonition":9,"contrition":1,"dominant":"admonition","rationale":"Prohibitions against sexual immorality and abominations practiced by surrounding nations, with severe warnings of defilement."},
    {"book":"Leviticus","chapter":19,"exaltation":3,"peace":6,"admonition":5,"contrition":0,"dominant":"peace","rationale":"The holiness code with the command to love thy neighbour as thyself, blending high moral instruction with social justice."},
    {"book":"Leviticus","chapter":20,"exaltation":1,"peace":2,"admonition":9,"contrition":2,"dominant":"admonition","rationale":"Penalties for violations of the holiness code, including idolatry and sexual sins, with repeated calls to be holy."},
    {"book":"Leviticus","chapter":21,"exaltation":2,"peace":4,"admonition":6,"contrition":0,"dominant":"admonition","rationale":"Regulations for priestly holiness and physical requirements, emphasizing that those who serve God must be set apart."},
    {"book":"Leviticus","chapter":22,"exaltation":2,"peace":5,"admonition":5,"contrition":0,"dominant":"peace","rationale":"Rules ensuring that offerings are without blemish and priests approach in cleanness, sanctifying the holy name of God."},
    {"book":"Leviticus","chapter":23,"exaltation":7,"peace":8,"admonition":2,"contrition":1,"dominant":"peace","rationale":"The appointed feasts of the Lord — Sabbath, Passover, Firstfruits, Pentecost, Trumpets, Atonement, Tabernacles — celebrating covenant blessings."},
    {"book":"Leviticus","chapter":24,"exaltation":2,"peace":3,"admonition":8,"contrition":2,"dominant":"admonition","rationale":"Includes the sacred lamps and showbread, but dominated by the severe case of blasphemy and the law of retaliation."},
    {"book":"Leviticus","chapter":25,"exaltation":4,"peace":8,"admonition":3,"contrition":0,"dominant":"peace","rationale":"Sabbatical year and Jubilee laws provide rest, liberation, and economic restoration — a vision of covenant peace and divine provision."},
    {"book":"Leviticus","chapter":26,"exaltation":5,"peace":5,"admonition":8,"contrition":6,"dominant":"admonition","rationale":"Blessings for obedience and severe curses for disobedience, but ending with the promise that God will remember His covenant."},
    {"book":"Leviticus","chapter":27,"exaltation":1,"peace":6,"admonition":3,"contrition":0,"dominant":"peace","rationale":"Laws concerning vows and dedications to the Lord, focusing on the valuation and redemption of persons and property."}
