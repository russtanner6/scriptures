  "crossReferences": [
    {"book":"Judges","chapter":2,"verse":10,"crossReference":"Deuteronomy 6:6-7","type":"allusion","note":"A generation arose that knew not the Lord, illustrating the failure to teach children as Moses commanded."},
    {"book":"Judges","chapter":5,"verse":4,"crossReference":"Deuteronomy 33:2","type":"parallel","note":"Both passages describe God going forth from Seir and the mountains trembling at His presence."},
    {"book":"Judges","chapter":6,"verse":12,"crossReference":"Luke 1:28","type":"typology","note":"The angel's greeting to Gideon parallels the angel Gabriel's greeting to Mary."},
