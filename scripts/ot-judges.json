    {"book":"Judges","chapter":9,"exaltation":0,"peace":0,"admonition":9,"contrition":3,"dominant":"admonition","rationale":"Abimelech's violent rise to power through fratricide, Jotham's parable of the trees, and Abimelech's violent end."},
    {"book":"Judges","chapter":10,"exaltation":1,"peace":2,"admonition":7,"contrition":6,"dominant":"admonition","rationale":"Israel's repeated idolatry brings oppression; their cry of repentance is met with divine rebuke before mercy."},
    {"book":"Judges","chapter":11,"exaltation":3,"peace":2,"admonition":5,"contrition":5,"dominant":"admonition","rationale":"Jephthah delivers Israel from Ammon but makes a rash vow with tragic consequences for his daughter."},
    {"book":"Judges","chapter":12,"exaltation":1,"peace":1,"admonition":7,"contrition":2,"dominant":"admonition","rationale":"Intertribal conflict between Ephraim and Gilead results in civil war and the death of 42,000 Ephraimites."},
