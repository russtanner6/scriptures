{
  "bookName": "2 Kings",
  "bookId": 12,
  "sentiment": [
    {"book":"2 Kings","chapter":1,"exaltation":3,"peace":0,"admonition":8,"contrition":2,"dominant":"admonition","rationale":"Elijah calls down fire from heaven on the captains of Ahaziah, demonstrating divine judgment on those who defy God's prophet."},
    {"book":"2 Kings","chapter":2,"exaltation":9,"peace":4,"admonition":2,"contrition":0,"dominant":"exaltation","rationale":"Elijah's dramatic ascent to heaven in a chariot of fire and the mantle passing to Elisha mark a glorious prophetic transition."},
    {"book":"2 Kings","chapter":3,"exaltation":3,"peace":3,"admonition":5,"contrition":2,"dominant":"admonition","rationale":"The campaign against Moab involves divine intervention through Elisha, but ends with the horror of the Moabite king sacrificing his son."},
    {"book":"2 Kings","chapter":4,"exaltation":7,"peace":7,"admonition":0,"contrition":1,"dominant":"peace","rationale":"A series of miraculous acts of mercy by Elisha: multiplying oil, raising the Shunammite's son, purifying the pot, and feeding a multitude."},
    {"book":"2 Kings","chapter":5,"exaltation":5,"peace":6,"admonition":4,"contrition":2,"dominant":"peace","rationale":"Naaman's healing from leprosy is a story of faith and humility, contrasted with Gehazi's punishment for greed."},
    {"book":"2 Kings","chapter":6,"exaltation":6,"peace":5,"admonition":3,"contrition":2,"dominant":"exaltation","rationale":"Elisha reveals heavenly hosts, blinds the Syrian army, and the siege of Samaria creates desperate famine conditions."},
    {"book":"2 Kings","chapter":7,"exaltation":5,"peace":6,"admonition":3,"contrition":0,"dominant":"peace","rationale":"God miraculously ends the siege of Samaria; the lepers discover the abandoned Syrian camp, and the doubting officer is trampled."},
    {"book":"2 Kings","chapter":8,"exaltation":1,"peace":2,"admonition":7,"contrition":4,"dominant":"admonition","rationale":"Hazael's brutal rise to power, the wicked reigns of Jehoram and Ahaziah of Judah, and the spread of Ahab's idolatrous influence."},
    {"book":"2 Kings","chapter":9,"exaltation":4,"peace":0,"admonition":9,"contrition":2,"dominant":"admonition","rationale":"Jehu is anointed and executes fierce judgment on the house of Ahab, killing Joram, Ahaziah, and Jezebel."},
    {"book":"2 Kings","chapter":10,"exaltation":2,"peace":0,"admonition":10,"contrition":1,"dominant":"admonition","rationale":"Jehu completes the destruction of Ahab's house and exterminates Baal worship from Israel through violent purges."},
    {"book":"2 Kings","chapter":11,"exaltation":6,"peace":5,"admonition":5,"contrition":0,"dominant":"exaltation","rationale":"Athaliah usurps the throne but Jehoiada the priest preserves Joash and restores the Davidic line in a dramatic covenant renewal."},
    {"book":"2 Kings","chapter":12,"exaltation":3,"peace":5,"admonition":3,"contrition":2,"dominant":"peace","rationale":"Joash repairs the temple under Jehoiada's guidance, but later bribes Hazael and is assassinated by his servants."},
    {"book":"2 Kings","chapter":13,"exaltation":2,"peace":3,"admonition":6,"contrition":3,"dominant":"admonition","rationale":"Israel suffers under Syrian oppression due to sin; Elisha's deathbed prophecy and posthumous miracle show lingering divine power."},
    {"book":"2 Kings","chapter":14,"exaltation":3,"peace":2,"admonition":6,"contrition":2,"dominant":"admonition","rationale":"Amaziah's partial obedience and pride lead to defeat by Israel; the period is marked by royal violence and instability."},
    {"book":"2 Kings","chapter":15,"exaltation":0,"peace":1,"admonition":9,"contrition":3,"dominant":"admonition","rationale":"A rapid succession of assassinations and wicked kings in Israel, with Assyria beginning to encroach on the northern kingdom."},
    {"book":"2 Kings","chapter":16,"exaltation":0,"peace":0,"admonition":10,"contrition":2,"dominant":"admonition","rationale":"Ahaz introduces pagan worship and even sacrifices his son, remodeling the temple altar after a Syrian pattern."},
    {"book":"2 Kings","chapter":17,"exaltation":0,"peace":0,"admonition":10,"contrition":3,"dominant":"admonition","rationale":"The fall of the northern kingdom to Assyria, with a lengthy theological explanation of Israel's persistent idolatry and rejection of God."},
    {"book":"2 Kings","chapter":18,"exaltation":6,"peace":5,"admonition":4,"contrition":2,"dominant":"exaltation","rationale":"Hezekiah's righteous reforms and trust in God contrast with the Assyrian Rabshakeh's blasphemous taunting of Jerusalem."},
    {"book":"2 Kings","chapter":19,"exaltation":8,"peace":6,"admonition":3,"contrition":1,"dominant":"exaltation","rationale":"Hezekiah's prayer and Isaiah's prophecy lead to the miraculous destruction of 185,000 Assyrian soldiers by the angel of the Lord."},
    {"book":"2 Kings","chapter":20,"exaltation":4,"peace":5,"admonition":4,"contrition":2,"dominant":"peace","rationale":"Hezekiah's illness and miraculous healing are tempered by the prophetic warning of Babylonian exile after he shows his treasures."},
    {"book":"2 Kings","chapter":21,"exaltation":0,"peace":0,"admonition":10,"contrition":2,"dominant":"admonition","rationale":"Manasseh's reign is the most wicked in Judah's history, filled with idolatry, sorcery, and the shedding of innocent blood."},
    {"book":"2 Kings","chapter":22,"exaltation":4,"peace":5,"admonition":5,"contrition":6,"dominant":"contrition","rationale":"The discovery of the Book of the Law causes deep penitence in Josiah, and Huldah confirms impending judgment tempered by mercy for the king."},
    {"book":"2 Kings","chapter":23,"exaltation":5,"peace":3,"admonition":7,"contrition":2,"dominant":"admonition","rationale":"Josiah's sweeping reforms purge idolatry from the land, but the narrator declares that God's wrath against Judah is already fixed."},
    {"book":"2 Kings","chapter":24,"exaltation":0,"peace":0,"admonition":10,"contrition":4,"dominant":"admonition","rationale":"Babylon besieges Jerusalem, carries away treasures and captives, and installs Zedekiah as a puppet king—the end approaches."},
    {"book":"2 Kings","chapter":25,"exaltation":0,"peace":1,"admonition":10,"contrition":7,"dominant":"admonition","rationale":"The destruction of Jerusalem and the temple, the exile to Babylon, the murder of Gedaliah, and a faint hope in Jehoiachin's release."}
