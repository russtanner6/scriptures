  "summaries": [
    {"book":"1 Kings","chapter":1,"summary":"Aging King David confirms Solomon as his successor after Adonijah attempts to seize the throne, with Nathan and Bathsheba intervening."},
    {"book":"1 Kings","chapter":2,"summary":"David gives Solomon his final charge and dies; Solomon secures his kingdom by dealing with Adonijah, Joab, and Shimei."},
    {"book":"1 Kings","chapter":3,"summary":"Solomon asks God for wisdom and receives it along with riches and honor; he demonstrates his wisdom by judging between two women claiming the same child."},
    {"book":"1 Kings","chapter":4,"summary":"Solomon's administrators, provisions, and dominion are described, along with his unparalleled wisdom and literary accomplishments."},
    {"book":"1 Kings","chapter":5,"summary":"Solomon makes an alliance with Hiram of Tyre to obtain materials and labor for building the temple of the Lord."},
    {"book":"1 Kings","chapter":6,"summary":"Solomon builds the temple over seven years with detailed descriptions of its structure, dimensions, and God's conditional promise."},
    {"book":"1 Kings","chapter":7,"summary":"Solomon builds his own palace over thirteen years and commissions elaborate bronze furnishings for the temple through Hiram the craftsman."},
    {"book":"1 Kings","chapter":8,"summary":"Solomon dedicates the temple with the Ark of the Covenant, offering a lengthy prayer of supplication and blessing upon all Israel."},
    {"book":"1 Kings","chapter":9,"summary":"God appears to Solomon a second time with promises and warnings; Solomon's building projects and dealings with Hiram are recorded."},
    {"book":"1 Kings","chapter":10,"summary":"The Queen of Sheba visits Solomon, marvels at his wisdom and wealth, and the extent of Solomon's riches is described."},
    {"book":"1 Kings","chapter":11,"summary":"Solomon's foreign wives turn his heart to other gods; the Lord raises adversaries and Ahijah prophesies the division of the kingdom."},
    {"book":"1 Kings","chapter":12,"summary":"Rehoboam's harshness causes the northern tribes to revolt under Jeroboam, who then establishes idol worship at Dan and Bethel."},
    {"book":"1 Kings","chapter":13,"summary":"A prophet from Judah prophesies against Jeroboam's altar but is later killed by a lion for disobeying God's command."},
    {"book":"1 Kings","chapter":14,"summary":"Ahijah prophesies the destruction of Jeroboam's dynasty; Rehoboam reigns in Judah amid spiritual decline and Egyptian invasion."},
    {"book":"1 Kings","chapter":15,"summary":"Abijam and Asa reign in Judah while Nadab and Baasha reign in Israel, with ongoing war between the two kingdoms."},
    {"book":"1 Kings","chapter":16,"summary":"A succession of wicked kings rules Israel—Baasha, Elah, Zimri, Omri—culminating in Ahab who introduces Baal worship."},
    {"book":"1 Kings","chapter":17,"summary":"Elijah declares a drought, is fed by ravens at the brook Cherith, then sustains a widow at Zarephath and raises her son from the dead."},
    {"book":"1 Kings","chapter":18,"summary":"Elijah challenges the prophets of Baal on Mount Carmel; fire falls from heaven, the people return to God, and rain comes after three years."},
    {"book":"1 Kings","chapter":19,"summary":"Elijah flees Jezebel's threat, is ministered to by an angel, encounters God in a still small voice, and anoints Elisha as his successor."},
    {"book":"1 Kings","chapter":20,"summary":"Israel defeats Syria twice through prophetic guidance, but Ahab is condemned for making a treaty with Ben-hadad instead of executing judgment."},
    {"book":"1 Kings","chapter":21,"summary":"Jezebel arranges Naboth's murder so Ahab can take his vineyard; Elijah pronounces divine judgment on Ahab and his house."},
    {"book":"1 Kings","chapter":22,"summary":"Micaiah prophesies Ahab's death despite the lies of false prophets; Ahab is killed at Ramoth-gilead and Jehoshaphat returns safely."}
  ],
