  "notableVerses": [
    {"book":"1 Kings","chapter":1,"verses":[{"verse":30,"reason":"David's oath to Bathsheba confirming Solomon as his successor—the pivotal moment of succession."}]},
    {"book":"1 Kings","chapter":2,"verses":[{"verse":2,"reason":"David's charge to Solomon to be strong and keep God's commandments—a famous deathbed exhortation."},{"verse":3,"reason":"Promise that obedience will bring prosperity in all endeavors."}]},
    {"book":"1 Kings","chapter":3,"verses":[{"verse":9,"reason":"Solomon's request for an understanding heart to judge the people—a model of righteous prayer."},{"verse":12,"reason":"God grants Solomon a wise and understanding heart unlike any before or after."}]},
    {"book":"1 Kings","chapter":4,"verses":[{"verse":29,"reason":"God gave Solomon wisdom and understanding exceeding great, as the sand on the sea shore."}]},
    {"book":"1 Kings","chapter":5,"verses":[]},
    {"book":"1 Kings","chapter":6,"verses":[{"verse":12,"reason":"God's conditional promise that He will dwell among Israel if Solomon walks in His statutes."}]},
    {"book":"1 Kings","chapter":7,"verses":[]},
    {"book":"1 Kings","chapter":8,"verses":[{"verse":27,"reason":"Solomon's acknowledgment that heaven and earth cannot contain God, much less the temple."},{"verse":46,"reason":"The declaration that there is no man who does not sin—a foundational statement on human nature."},{"verse":56,"reason":"Praise that not one word of God's good promises has failed."}]},
    {"book":"1 Kings","chapter":9,"verses":[{"verse":3,"reason":"God hallows the temple and promises His name and heart will be there perpetually."}]},
    {"book":"1 Kings","chapter":10,"verses":[{"verse":7,"reason":"The Queen of Sheba declares the half was not told regarding Solomon's wisdom and prosperity."}]},
    {"book":"1 Kings","chapter":11,"verses":[{"verse":4,"reason":"Solomon's heart was turned after other gods and was not perfect as David's—a warning about apostasy."}]},
    {"book":"1 Kings","chapter":12,"verses":[{"verse":16,"reason":"The cry of rebellion: 'What portion have we in David?' that splits the kingdom permanently."}]},
    {"book":"1 Kings","chapter":13,"verses":[]},
    {"book":"1 Kings","chapter":14,"verses":[]},
    {"book":"1 Kings","chapter":15,"verses":[]},
    {"book":"1 Kings","chapter":16,"verses":[{"verse":30,"reason":"Ahab did more evil in the sight of the LORD than all the kings before him."}]},
    {"book":"1 Kings","chapter":17,"verses":[{"verse":14,"reason":"Elijah's promise that the barrel of meal and cruse of oil shall not fail—a paradigm of divine provision."},{"verse":22,"reason":"The Lord heard Elijah's voice and the child's soul came into him again—a dramatic resurrection."}]},
    {"book":"1 Kings","chapter":18,"verses":[{"verse":21,"reason":"Elijah's challenge: 'How long halt ye between two opinions?'—a call to decisive commitment."},{"verse":38,"reason":"The fire of the LORD fell and consumed the burnt sacrifice—the climactic moment on Carmel."}]},
    {"book":"1 Kings","chapter":19,"verses":[{"verse":11,"reason":"God was not in the wind, earthquake, or fire—anticipating the still small voice revelation."},{"verse":12,"reason":"After the fire a still small voice—one of the most quoted descriptions of divine communication."},{"verse":18,"reason":"Seven thousand in Israel who have not bowed to Baal—a remnant of the faithful."}]},
