    {"book":"1 Kings","chapter":2,"exaltation":2,"peace":3,"admonition":7,"contrition":2,"dominant":"admonition","rationale":"David's final charge and Solomon's consolidation of power through decisive judgment against his enemies."},
    {"book":"1 Kings","chapter":3,"exaltation":7,"peace":8,"admonition":0,"contrition":1,"dominant":"peace","rationale":"Solomon's humble request for wisdom is blessed by God, demonstrated in the famous judgment between two mothers."},
    {"book":"1 Kings","chapter":4,"exaltation":6,"peace":8,"admonition":0,"contrition":0,"dominant":"peace","rationale":"A portrait of the prosperity and peace of Solomon's kingdom, with his wisdom surpassing all others."},
    {"book":"1 Kings","chapter":5,"exaltation":4,"peace":7,"admonition":0,"contrition":0,"dominant":"peace","rationale":"Solomon prepares to build the temple through a peaceful alliance with Hiram king of Tyre."},
    {"book":"1 Kings","chapter":6,"exaltation":8,"peace":7,"admonition":1,"contrition":0,"dominant":"exaltation","rationale":"The detailed construction of Solomon's temple, a magnificent house for the Lord's presence."},
    {"book":"1 Kings","chapter":7,"exaltation":5,"peace":6,"admonition":0,"contrition":0,"dominant":"peace","rationale":"Describes Solomon's palace and the elaborate furnishings crafted by Hiram for the temple."},
    {"book":"1 Kings","chapter":8,"exaltation":9,"peace":8,"admonition":2,"contrition":3,"dominant":"exaltation","rationale":"Solomon's dedicatory prayer at the temple, filled with praise, supplication, and recognition of God's covenant faithfulness."},
    {"book":"1 Kings","chapter":9,"exaltation":4,"peace":5,"admonition":6,"contrition":0,"dominant":"admonition","rationale":"God's conditional promise to Solomon—blessing for obedience, destruction for apostasy."},
    {"book":"1 Kings","chapter":10,"exaltation":8,"peace":7,"admonition":0,"contrition":0,"dominant":"exaltation","rationale":"The Queen of Sheba visits Solomon and is overwhelmed by his wisdom and splendor."},
    {"book":"1 Kings","chapter":11,"exaltation":0,"peace":1,"admonition":9,"contrition":3,"dominant":"admonition","rationale":"Solomon's apostasy through foreign wives leads to divine judgment and the raising of adversaries."},
    {"book":"1 Kings","chapter":12,"exaltation":0,"peace":1,"admonition":8,"contrition":2,"dominant":"admonition","rationale":"Rehoboam's harsh response splits the kingdom; Jeroboam leads the northern tribes into idolatry."},
    {"book":"1 Kings","chapter":13,"exaltation":2,"peace":1,"admonition":8,"contrition":3,"dominant":"admonition","rationale":"A man of God prophesies against Jeroboam's altar but is killed for disobedience to God's direct command."},
    {"book":"1 Kings","chapter":14,"exaltation":0,"peace":0,"admonition":9,"contrition":4,"dominant":"admonition","rationale":"Ahijah prophesies the destruction of Jeroboam's house; Judah also falls into idolatry under Rehoboam."},
    {"book":"1 Kings","chapter":15,"exaltation":2,"peace":2,"admonition":7,"contrition":2,"dominant":"admonition","rationale":"A record of kings in Judah and Israel, measuring each by faithfulness; Asa's reforms contrasted with northern apostasy."},
    {"book":"1 Kings","chapter":16,"exaltation":0,"peace":0,"admonition":9,"contrition":2,"dominant":"admonition","rationale":"A rapid succession of wicked kings in Israel culminating in Ahab, who did more evil than all before him."},
    {"book":"1 Kings","chapter":17,"exaltation":7,"peace":6,"admonition":2,"contrition":1,"dominant":"exaltation","rationale":"Elijah is sustained by ravens and a widow; he raises the widow's son from the dead, demonstrating God's power."},
    {"book":"1 Kings","chapter":18,"exaltation":9,"peace":4,"admonition":5,"contrition":1,"dominant":"exaltation","rationale":"The dramatic contest on Mount Carmel where Elijah defeats the prophets of Baal and fire falls from heaven."},
    {"book":"1 Kings","chapter":19,"exaltation":5,"peace":6,"admonition":2,"contrition":5,"dominant":"peace","rationale":"Elijah flees from Jezebel, encounters God in the still small voice, and receives a new commission."},
    {"book":"1 Kings","chapter":20,"exaltation":3,"peace":2,"admonition":7,"contrition":1,"dominant":"admonition","rationale":"Israel defeats Syria twice by divine aid, but Ahab is rebuked for sparing Ben-hadad."},
    {"book":"1 Kings","chapter":21,"exaltation":0,"peace":0,"admonition":10,"contrition":4,"dominant":"admonition","rationale":"Jezebel orchestrates Naboth's murder for his vineyard; Elijah pronounces God's severe judgment on Ahab's house."},
